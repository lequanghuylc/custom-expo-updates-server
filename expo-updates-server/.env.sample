## Required for local (filesystem) mode and manifest URLs
HOSTNAME=http://localhost:3000

## Select where artifacts are stored / served from:
## - local: store extracted exports on disk (recommended for single-instance with a volume)
## - s3: store exports in S3 and return S3 URLs in manifests
ARTIFACT_MODE=local

## If you still have clients pointing at `/api/manifest` (legacy), this slug will be used.
## New clients should use `/api/<slug>/manifest` instead.
# DEFAULT_APP_SLUG=default

## Local artifacts root directory. When set, local mode will store updates under:
##   $ARTIFACTS_DIR/updates/<runtimeVersion>/<channel>/<platform>/<updateId>/
## and serve assets from there.
##
## If not set, the server falls back to the repo-local `./updates/` folder (legacy PoC).
# ARTIFACTS_DIR=/var/lib/expo-updates

## Optional: enable code signing responses (server will sign manifests/directives)
## Used by `yarn dev` / `yarn start` scripts via PRIVATE_KEY_PATH
# PRIVATE_KEY_PATH=code-signing-keys/private-key.pem

## -----------------------------
## S3-backed Updates (V1)
## -----------------------------
## Only used when ARTIFACT_MODE=s3 (or when S3_BUCKET is set and ARTIFACT_MODE is not set)
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1

## Public base URL where objects are reachable (often fronted by CDN)
## Examples:
## - https://your-bucket.s3.us-east-1.amazonaws.com
## - https://cdn.your-domain.com
S3_PUBLIC_BASE_URL=https://your-bucket.s3.us-east-1.amazonaws.com

## Optional: restrict who can publish updates
## If set, `POST /api/updates/upload` requires: Authorization: Bearer <UPLOAD_TOKEN>
# UPLOAD_TOKEN=replace-me

## AWS credentials (if not provided by instance role / env / AWS profile)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

